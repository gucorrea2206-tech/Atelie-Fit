rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required) - Product name
    //   - createdAt: timestamp (required) - Creation time
    //
    // Collection: movements
    // Document ID: auto-generated
    // Fields:
    //   - productId: string (required) - Reference to product
    //   - type: string (required, enum: ['entrada', 'saida']) - Movement type
    //   - quantity: int (required, positive) - Quantity moved
    //   - createdAt: timestamp (required) - Movement time
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ateliefitlondrina@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('price' in data) || data.price is number) &&
             data.createdAt is timestamp;
    }

    function isValidMovement(data) {
      return data.keys().hasAll(['productId', 'type', 'quantity', 'createdAt']) &&
             data.productId is string &&
             data.type in ['entrada', 'saida'] &&
             data.quantity is int && data.quantity > 0 &&
             data.createdAt is timestamp;
    }

    function isValidKit(data) {
      return data.keys().hasAll(['name', 'items', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('price' in data) || data.price is number) &&
             data.items is list && data.items.size() > 0 && data.items.size() < 50 &&
             data.createdAt is timestamp;
    }

    function isValidSupplier(data) {
      return data.keys().hasAll(['name', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.createdAt is timestamp;
    }

    function isValidShoppingProduct(data) {
      return data.keys().hasAll(['name', 'supplierId', 'unit', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.supplierId is string &&
             data.unit is string &&
             data.createdAt is timestamp;
    }

    function isValidBill(data) {
      return data.keys().hasAll(['name', 'value', 'dueDate', 'isPaid', 'isRecurring', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.value is number &&
             data.dueDate is timestamp &&
             data.isPaid is bool &&
             data.isRecurring is bool &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.role == 'user';
      allow update: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidProduct(request.resource.data);
      allow update: if isAuthenticated() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /movements/{movementId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMovement(request.resource.data);
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /kits/{kitId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidKit(request.resource.data);
      allow update: if isAuthenticated() && isValidKit(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /suppliers/{supplierId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSupplier(request.resource.data);
      allow update: if isAuthenticated() && isValidSupplier(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /shoppingProducts/{productId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidShoppingProduct(request.resource.data);
      allow update: if isAuthenticated() && isValidShoppingProduct(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /bills/{billId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBill(request.resource.data);
      allow update: if isAuthenticated() && isValidBill(request.resource.data);
      allow delete: if isAuthenticated();
    }
  }
}
